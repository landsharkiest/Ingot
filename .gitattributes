# Normalize line endings: LF in the repo for everything text, so the
# dotnet-format end_of_line=lf check is deterministic across Windows/Linux.
* text=auto eol=lf

# Windows-only scripts keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.snk binary
*.nupkg binary
